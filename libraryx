-- ==================== WIND UI NOTIFICATION SYSTEM WITH FULL OVERLAY PROGRESS ====================
local ActiveNotifications = {}
local TweenService = game:GetService("TweenService")
local Player = game.Players.LocalPlayer

local function RepositionNotifications()
    local notifHeight = 60
    local spacing = 8

    for i, frame in ipairs(ActiveNotifications) do
        local targetY = 15 + ((i - 1) * (notifHeight + spacing))

        TweenService:Create(
            frame,
            TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out),
            {
                Position = UDim2.new(1, -280, 0, targetY)
            }
        ):Play()
    end
end

function Speed_Library:ShowNotification(title, description, duration, showProgress)
    duration = duration or 5
    showProgress = showProgress ~= false

    local ScreenGui = Player.PlayerGui:FindFirstChild("WindNotifications")

    if not ScreenGui then
        ScreenGui = Instance.new("ScreenGui")
        ScreenGui.Name = "WindNotifications"
        ScreenGui.ResetOnSpawn = false
        ScreenGui.Parent = Player.PlayerGui
    end

    local notifHeight = 60
    local spacing = 8

    local index = #ActiveNotifications + 1
    local targetY = 15 + ((index - 1) * (notifHeight + spacing))

    local Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(0, 260, 0, notifHeight)
    Frame.Position = UDim2.new(1, 20, 0, targetY)
    Frame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    Frame.BackgroundTransparency = 0.4
    Frame.BorderSizePixel = 0
    Frame.ClipsDescendants = true
    Frame.Parent = ScreenGui

    table.insert(ActiveNotifications, Frame)

    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(0, 8)
    Corner.Parent = Frame

    local Stroke = Instance.new("UIStroke")
    Stroke.Color = Color3.fromRGB(239, 68, 68)
    Stroke.Thickness = 1.5
    Stroke.Parent = Frame

    -- FULL PROGRESS OVERLAY
    if showProgress then
        local ProgressOverlay = Instance.new("Frame")
        ProgressOverlay.Size = UDim2.new(1, 0, 1, 0)
        ProgressOverlay.Position = UDim2.new(0, 0, 0, 0)
        ProgressOverlay.BackgroundColor3 = Color3.fromRGB(239, 68, 68)
        ProgressOverlay.BackgroundTransparency = 0.5
        ProgressOverlay.BorderSizePixel = 0
        ProgressOverlay.ZIndex = 1
        ProgressOverlay.Parent = Frame

        local ProgressCorner = Instance.new("UICorner")
        ProgressCorner.CornerRadius = UDim.new(0, 8)
        ProgressCorner.Parent = ProgressOverlay

        TweenService:Create(
            ProgressOverlay,
            TweenInfo.new(duration, Enum.EasingStyle.Linear),
            {
                Size = UDim2.new(0, 0, 1, 0)
            }
        ):Play()
    end

    local Title = Instance.new("TextLabel")
    Title.BackgroundTransparency = 1
    Title.Position = UDim2.new(0, 12, 0, 5)
    Title.Size = UDim2.new(1, -24, 0, 18)
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 14
    Title.TextColor3 = Color3.fromRGB(255, 255, 255)
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.Text = tostring(title)
    Title.ZIndex = 2
    Title.Parent = Frame

    local Desc = Instance.new("TextLabel")
    Desc.BackgroundTransparency = 1
    Desc.Position = UDim2.new(0, 12, 0, 24)
    Desc.Size = UDim2.new(1, -24, 0, 28)
    Desc.Font = Enum.Font.Gotham
    Desc.TextSize = 12
    Desc.TextColor3 = Color3.fromRGB(220, 220, 220)
    Desc.TextWrapped = true
    Desc.TextXAlignment = Enum.TextXAlignment.Left
    Desc.TextYAlignment = Enum.TextYAlignment.Top
    Desc.Text = tostring(description)
    Desc.ZIndex = 2
    Desc.Parent = Frame

    TweenService:Create(
        Frame,
        TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
        {
            Position = UDim2.new(1, -280, 0, targetY)
        }
    ):Play()

    task.delay(duration, function()
        if Frame and Frame.Parent then
            local SlideOut = TweenService:Create(
                Frame,
                TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In),
                {
                    Position = UDim2.new(1, 20, 0, targetY)
                }
            )

            SlideOut:Play()

            SlideOut.Completed:Connect(function()
                for i, v in ipairs(ActiveNotifications) do
                    if v == Frame then
                        table.remove(ActiveNotifications, i)
                        break
                    end
                end

                Frame:Destroy()

                RepositionNotifications()

                if #ActiveNotifications == 0 and ScreenGui then
                    ScreenGui:Destroy()
                end
            end)
        end
    end)
end

function Speed_Library:SetNotification(Config)
    local Title = Config.Title or Config[1] or "Notification"
    local Description = Config.Description or Config.Content or Config[2] or ""
    local Duration = Config.Duration or Config[5] or 3.5
    local ShowProgress = Config.Progress ~= false

    self:ShowNotification(
        Title,
        Description,
        Duration,
        ShowProgress
    )
end

function Speed_Library:Notify(Config)
    self:SetNotification(Config)
end

