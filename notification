local function IsPlayerVisible(targetCharacter)
    if not WallCheckEnabled then return true end
    
    local myChar = LocalPlayer.Character
    local myRootPart = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local targetRootPart = targetCharacter and targetCharacter:FindFirstChild("HumanoidRootPart")
    
    if not (myRootPart and targetRootPart) then return false end
    
    local rayOrigin = myRootPart.Position
    local rayDirection = (targetRootPart.Position - rayOrigin).Unit
    local rayLength = (targetRootPart.Position - rayOrigin).Magnitude
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = {myChar}
    
    local rayResult = workspace:Raycast(rayOrigin, rayDirection * rayLength, raycastParams)
    
    if rayResult then
        local hitPart = rayResult.Instance
        local hitCharacter = hitPart:FindFirstAncestorOfClass("Model")
        
        if hitCharacter == targetCharacter then
            return true
        else
            return false
        end
    end
    
    return true
end

local function FindClosestTarget()
    local closestPlayer = nil
    local closestDistance = AimbotFOV
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, player in pairs(game.Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local isTargetTeam = false
            
            if TeamCheckAimbot then
                for _, targetTeam in pairs(TargetTeams) do
                    if player.Team == targetTeam then
                        isTargetTeam = true
                        break
                    end
                end
                
                if not isTargetTeam then
                    continue
                end
            end

            local character = player.Character
            local humanoid = character and character:FindFirstChild("Humanoid")
            local targetPart = character and character:FindFirstChild("Head")

            if character and humanoid and targetPart and humanoid.Health > 0 then
                if not IsPlayerVisible(character) then
                    continue
                end
                
                local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                
                if onScreen then
                    local distance = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
                    
                    if distance < closestDistance then
                        closestDistance = distance
                        closestPlayer = player
                    end
                end
            end
        end
    end

    return closestPlayer
end

local function StartAimbot()
    if aimbotConnection then aimbotConnection:Disconnect() end
    
    aimbotConnection = game:GetService("RunService").RenderStepped:Connect(function()
        if not AimbotEnabled then return end

        UpdateFOVCircle()

        TargetPlayer = FindClosestTarget()

        if TargetPlayer then
            local character = TargetPlayer.Character
            local targetPart = character and character:FindFirstChild("Head")

            if targetPart then
                local targetPosition = targetPart.Position
                
                if PredictionEnabled then
                    local humanoid = character:FindFirstChild("Humanoid")
                    if humanoid then
                        targetPosition = targetPosition + (humanoid.MoveDirection * 2)
                    end
                end
                
                local cameraPosition = Camera.CFrame.Position
                local direction = (targetPosition - cameraPosition).Unit

                local currentDirection = Camera.CFrame.LookVector
                local smoothValue = AimbotSmooth / 100
                local smoothedDirection = currentDirection:Lerp(direction, smoothValue)

                Camera.CFrame = CFrame.new(cameraPosition, cameraPosition + smoothedDirection)
            end
        end
    end)
end

