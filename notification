    if isSilent and ProcessingPlayers[player] then return end
    if humanoid.Health <= 0 then return end

    -- LOCK MUSUH INI SAAT PAKAI SILENT AIM
    if isSilent then
        ProcessingPlayers[player] = true
    end
    
    local oldHealth = humanoid.Health
    local startTime = tick()
    local hasPlayedHitSound = false

    local conn
    conn = game:GetService("RunService").Heartbeat:Connect(function()
        if not character or not character.Parent or not humanoid or not humanoid.Parent then
            ResetKillStatus(player)
            if conn then conn:Disconnect() end
            return
        end

        local newHealth = humanoid.Health
        local damage = math.max(0, oldHealth - newHealth)

        -- Jika HP benar-benar berkurang
        if damage > 0 then
            oldHealth = newHealth 

            -- [FIX 100X] HIT SOUND: Cuma mainkan 1x per hit tick menggunakan cooldown pemain
            if getgenv().HitSoundEnabled and not hasPlayedHitSound then
                hasPlayedHitSound = true -- Kunci supaya tidak spam suara di frame yang sama
                task.spawn(function()
                    local sound = Instance.new("Sound")
                    sound.SoundId = getgenv().SelectedHitSoundId or "rbxassetid://94970221280272"
                    sound.Volume = 0.5
                    sound.Parent = workspace
                    sound:Play()
                    game:GetService("Debris"):AddItem(sound, 2)
                    
                    -- Reset kunci suara setelah 0.2 detik agar bisa bunyi lagi untuk hit berikutnya
                    task.delay(0.2, function()
                        hasPlayedHitSound = false
                    end)
                end)
            end

            -- [FIX 100X] DAMAGE LOGS: Pakai Global Cooldown per pemain (0.5 detik) biar tidak flood notif
            if getgenv().HitLogsEnabled then
                local now = tick()
                if not NotifCooldown[player] or (now - NotifCooldown[player] > 0.5) then
                    NotifCooldown[player] = now
                    Speed_Library:ShowNotification(
                        "Damage Logs",
                        string.format("%s\n -%.0f HP (%.0f HP Left)", player.Name, damage, newHealth),
                        2
                    )
                end
            end
        end

        -- Jika Musuh Mati
        if newHealth <= 0 and not KilledPlayers[player] then
            KilledPlayers[player] = true
            
            -- [FIX 100X] KILL LOGS: Hanya muncul 1x saat mati
            if getgenv().KillLogsEnabled then
                Speed_Library:ShowNotification(
                    "Kill Logs",
                    ""..player.Name.." Killed",
                    3
                )
            end

            -- Sistem Killstreak
            if getgenv().KillStreakEnabled then
                local currentTime = tick()
                
                if currentTime - LastKillTime > KillStreakResetTime and LastKillTime ~= 0 then
                    CurrentKillStreak = 0
                end
                
                LastKillTime = currentTime
                CurrentKillStreak = CurrentKillStreak + 1
                
                local streakData = KillStreakList[CurrentKillStreak] or KillStreakList[#KillStreakList]
                
                -- [FIX 100X] KILLSTREAK SOUND: Pakai Global Cooldown biar tidak overlaping
                local now = tick()
                if not SoundCooldown["Killstreak"] or (now - SoundCooldown["Killstreak"] > 1) then
                    SoundCooldown["Killstreak"] = now
                    task.spawn(function()
                        local sound = Instance.new("Sound")
                        sound.SoundId = streakData.id
                        sound.Volume = 0.8
                        sound.Parent = workspace
                        sound:Play()
                        game:GetService("Debris"):AddItem(sound, 3)
                    end)
                end
                
                Speed_Library:ShowNotification(
                    "Killstreak",
                    string.format("%s (Streak: %d)", streakData.name, CurrentKillStreak),
                    3
                )
            end

            ResetKillStatus(player)
            if conn then conn:Disconnect() end
            return
        end

        -- Failsafe: Jika sudah 2 detik tidak ada damage lagi
        if tick() - startTime > 2 then
            ResetKillStatus(player)
            if conn then conn:Disconnect() end
        end
    end)
end

