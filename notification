local function makeGunAutoFire(tool)
    if gunConnections[tool] then return end
    
    local connection
    connection = RunService.Heartbeat:Connect(function()
        if not tool or not tool.Parent then
            if connection then
                connection:Disconnect()
                gunConnections[tool] = nil
            end
            return
        end
        
        if not AutoFireEnabled then return end
        
        pcall(function()
            tool:SetAttribute("AutoFire", true)
        end)
        
        for _, descendant in pairs(tool:GetDescendants()) do
            if descendant:IsA("RemoteEvent") then
                if descendant.Name:match("Fire") or descendant.Name:match("Shoot") then
                    pcall(function()
                        descendant:FireServer()
                    end)
                end
            end
        end
    end)
    
    gunConnections[tool] = connection
    
    tool.Unequipped:Connect(function()
        if gunConnections[tool] then
            gunConnections[tool]:Disconnect()
            gunConnections[tool] = nil
        end
    end)
end

local function makeRateFireHack(tool)
    local connection
    connection = RunService.Heartbeat:Connect(function()
        if not tool or not tool.Parent then
            if connection then
                connection:Disconnect()
            end
            return
        end
        
        if not RateFireEnabled then return end
        
        pcall(function()
            local originalFireRate = tool:GetAttribute("FireRate") or 0.1
            tool:SetAttribute("FireRate", originalFireRate * 0.3)
        end)
    end)
    
    tool.Unequipped:Connect(function()
        if connection then
            connection:Disconnect()
        end
    end)
end

local function setupGunAutoFire(character)
    if not character then return end
    currentCharacter = character
    
    for _, tool in pairs(character:GetChildren()) do
        if tool:IsA("Tool") then
            if AutoFireEnabled then
