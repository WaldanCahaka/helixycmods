-- ==================== HELPER: DRAW 3D BOX ====================
local function Draw3DBox(boxLines, character, color, visible)
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    
    local boxCFrame, boxSize = character:GetBoundingBox()
    local x = boxSize.X / 2
    local y = boxSize.Y / 2
    local z = boxSize.Z / 2

    local corners = {
        (boxCFrame * CFrame.new(-x, -y,  z)).Position,
        (boxCFrame * CFrame.new( x, -y,  z)).Position,
        (boxCFrame * CFrame.new( x, -y, -z)).Position,
        (boxCFrame * CFrame.new(-x, -y, -z)).Position,
        (boxCFrame * CFrame.new(-x,  y,  z)).Position,
        (boxCFrame * CFrame.new( x,  y,  z)).Position,
        (boxCFrame * CFrame.new( x,  y, -z)).Position,
        (boxCFrame * CFrame.new(-x,  y, -z)).Position,
    }

    local edges = {
        {1,2}, {2,3}, {3,4}, {4,1},
        {5,6}, {6,7}, {7,8}, {8,5},
        {1,5}, {2,6}, {3,7}, {4,8}
    }

    for i, edge in ipairs(edges) do
        if boxLines[i] then
            local p1 = corners[edge[1]]
            local p2 = corners[edge[2]]
            
            local pos1, onScreen1 = Camera:WorldToViewportPoint(p1)
            local pos2, onScreen2 = Camera:WorldToViewportPoint(p2)
            
            if onScreen1 and onScreen2 and pos1.Z > 0 and pos2.Z > 0 then
                boxLines[i].From = Vector2.new(pos1.X, pos1.Y)
                boxLines[i].To = Vector2.new(pos2.X, pos2.Y)
                boxLines[i].Color = color
                boxLines[i].Visible = visible
            else
                boxLines[i].Visible = false
            end
        end
    end
end

-- ==================== HELPER: DRAW HEALTH BAR ====================
local function DrawHealthBar(healthBarLines, character, visible)
    if not character or not character:FindFirstChild("Humanoid") then return end
    
    local humanoid = character:FindFirstChild("Humanoid")
    local boxCFrame, boxSize = character:GetBoundingBox()
    
    local x = boxSize.X / 2
    local y = boxSize.Y / 2
    local z = boxSize.Z / 2
    local healthPerc = humanoid.Health / humanoid.MaxHealth
    
    -- Health bar background
    local barBackCorners = {
        (boxCFrame * CFrame.new(-x - 0.5, -y, z)).Position,
        (boxCFrame * CFrame.new(-x - 0.5, y, z)).Position,
        (boxCFrame * CFrame.new(-x - 0.5, y, -z)).Position,
        (boxCFrame * CFrame.new(-x - 0.5, -y, -z)).Position,
    }
    
    -- Health bar fill
    local barFillCorners = {
        (boxCFrame * CFrame.new(-x - 0.5, -y, z)).Position,
        (boxCFrame * CFrame.new(-x - 0.5, -y + (boxSize.Y * healthPerc), z)).Position,
        (boxCFrame * CFrame.new(-x - 0.5, -y + (boxSize.Y * healthPerc), -z)).Position,
        (boxCFrame * CFrame.new(-x - 0.5, -y, -z)).Position,
    }
    
    local barEdges = {
        {1,2}, {2,3}, {3,4}, {4,1}
    }
    
    for i, edge in ipairs(barEdges) do
        if healthBarLines.background[i] then
            local p1 = barBackCorners[edge[1]]
            local p2 = barBackCorners[edge[2]]
            
            local pos1, onScreen1 = Camera:WorldToViewportPoint(p1)
            local pos2, onScreen2 = Camera:WorldToViewportPoint(p2)
            
            if onScreen1 and onScreen2 and pos1.Z > 0 and pos2.Z > 0 then
                healthBarLines.background[i].From = Vector2.new(pos1.X, pos1.Y)
                healthBarLines.background[i].To = Vector2.new(pos2.X, pos2.Y)
                healthBarLines.background[i].Color = Color3.fromRGB(0, 0, 0)
                healthBarLines.background[i].Visible = visible
            else
                healthBarLines.background[i].Visible = false
            end
        end
    end
    
    for i, edge in ipairs(barEdges) do
        if healthBarLines.fill[i] then
            local p1 = barFillCorners[edge[1]]
            local p2 = barFillCorners[edge[2]]
            
            local pos1, onScreen1 = Camera:WorldToViewportPoint(p1)
            local pos2, onScreen2 = Camera:WorldToViewportPoint(p2)
            
            if onScreen1 and onScreen2 and pos1.Z > 0 and pos2.Z > 0 then
                healthBarLines.fill[i].From = Vector2.new(pos1.X, pos1.Y)
                healthBarLines.fill[i].To = Vector2.new(pos2.X, pos2.Y)
                healthBarLines.fill[i].Color = Color3.fromHSV(healthPerc * 0.33, 1, 1)
                healthBarLines.fill[i].Visible = visible
            else
                healthBarLines.fill[i].Visible = false
            end
        end
    end
end

-- ==================== HELPER: GET TEXT POSITIONS ====================
local function GetESPTextPositions(character, rootPart)
    local screenPos = Camera:WorldToViewportPoint(rootPart.Position)
    local boxCFrame, boxSize = character:GetBoundingBox()
    
    local topPoint = (boxCFrame * CFrame.new(0, boxSize.Y / 2, 0)).Position
    local bottomPoint = (boxCFrame * CFrame.new(0, -boxSize.Y / 2, 0)).Position
    
    local topScreen = Camera:WorldToViewportPoint(topPoint)
    local bottomScreen = Camera:WorldToViewportPoint(bottomPoint)
    
    return {
        top = Vector2.new(topScreen.X, topScreen.Y),
        bottom = Vector2.new(bottomScreen.X, bottomScreen.Y),
        center = Vector2.new(screenPos.X, screenPos.Y)
    }
end

-- ==================== HELPER: GET PLAYER TOOL WITH TRACKING ====================
local function SetupToolTracking(player, character, esp)
    if esp.ToolConnections then
        for _, conn in pairs(esp.ToolConnections) do
            pcall(function() conn:Disconnect() end)
        end
    end
    esp.ToolConnections = {}
    esp.CurrentToolName = "No Tool"
    
    local existingTool = character:FindFirstChildOfClass("Tool")
    if existingTool then
        esp.CurrentToolName = existingTool.Name
    end
    
    local childAddedConn = character.ChildAdded:Connect(function(child)
        if child:IsA("Tool") then
            esp.CurrentToolName = child.Name
        end
    end)
    table.insert(esp.ToolConnections, childAddedConn)
    
    local childRemovedConn = character.ChildRemoved:Connect(function(child)
        if child:IsA("Tool") then
            local toolStillExists = character:FindFirstChildOfClass("Tool")
            if not toolStillExists then
                esp.CurrentToolName = "No Tool"
            else
                esp.CurrentToolName = toolStillExists.Name
            end
        end
    end)
    table.insert(esp.ToolConnections, childRemovedConn)
end

-- ==================== CREATE ESP ====================
local function CreateESP(player)
    if player == LocalPlayer then return end
    if ESPObjects[player] then return end

    local esp = {
        Connections = {},
        BoxLines = {},
        HealthBarLines = { background = {}, fill = {} },
        Name = Drawing.new("Text"),
        Distance = Drawing.new("Text"),
        Tool = Drawing.new("Text"),
        Line = Drawing.new("Line"),
        CurrentToolName = "No Tool",
        ToolConnections = {}
    }

    for i = 1, 12 do
        local line = Drawing.new("Line")
        line.Thickness = 2
        line.Transparency = 1
        line.Visible = false
        table.insert(esp.BoxLines, line)
    end

    for i = 1, 4 do
        local bgLine = Drawing.new("Line")
        bgLine.Thickness = 3
        bgLine.Transparency = 1
        bgLine.Visible = false
        table.insert(esp.HealthBarLines.background, bgLine)
        
        local fillLine = Drawing.new("Line")
        fillLine.Thickness = 3
        fillLine.Transparency = 1
        fillLine.Visible = false
        table.insert(esp.HealthBarLines.fill, fillLine)
    end

    esp.Name.Size = 15
    esp.Name.Center = true
    esp.Name.Outline = true
    esp.Name.Visible = false

    esp.Distance.Size = 13
    esp.Distance.Center = true
    esp.Distance.Outline = true
    esp.Distance.Visible = false

    esp.Tool.Size = 12
    esp.Tool.Center = true
    esp.Tool.Outline = true
    esp.Tool.Visible = false

    esp.Line.Thickness = 1
    esp.Line.Visible = false

    ESPObjects[player] = esp

    -- HELPER: Hide semua ESP
    local function HideAllESP()
        for _, line in pairs(esp.BoxLines) do line.Visible = false end
        for _, line in pairs(esp.HealthBarLines.background) do line.Visible = false end
        for _, line in pairs(esp.HealthBarLines.fill) do line.Visible = false end
        esp.Name.Visible = false
        esp.Distance.Visible = false
        esp.Tool.Visible = false
        esp.Line.Visible = false
    end

    local function UpdateESP()
        if not ESPEnabled then 
            HideAllESP()
            return 
        end

        local character = player.Character
        local rootPart = character and character:FindFirstChild("HumanoidRootPart")
        local humanoid = character and character:FindFirstChild("Humanoid")

        if not (character and rootPart and humanoid and humanoid.Health > 0) then
            HideAllESP()
            return
        end

        local _, onScreen = Camera:WorldToViewportPoint(rootPart.Position)

        if not onScreen then
            HideAllESP()
            return
        end

        if TeamCheckEsp and player.Team == LocalPlayer.Team then
            HideAllESP()
            return
        end

        local finalBoxColor = UseTeamColor and player.Team and player.Team.TeamColor.Color or BoxColor
        local finalLineColor = UseTeamColor and player.Team and player.Team.TeamColor.Color or LineColor
        local finalNameColor = UseTeamColor and player.Team and player.Team.TeamColor.Color or NameColor

        if ShowBox then
            Draw3DBox(esp.BoxLines, character, finalBoxColor, true)
        else
            for _, line in pairs(esp.BoxLines) do line.Visible = false end
        end

        if ShowHealthBar then
            DrawHealthBar(esp.HealthBarLines, character, true)
        else
            for _, line in pairs(esp.HealthBarLines.background) do line.Visible = false end
            for _, line in pairs(esp.HealthBarLines.fill) do line.Visible = false end
        end

        local textPos = GetESPTextPositions(character, rootPart)

        if ShowName then
            esp.Name.Text = string.format("%s [%d HP]", player.Name, math.floor(humanoid.Health))
            esp.Name.Position = Vector2.new(textPos.top.X, textPos.top.Y - 25)
            esp.Name.Color = finalNameColor
            esp.Name.Visible = true
        else
            esp.Name.Visible = false
        end

        if ShowDistance then
            local myChar = LocalPlayer.Character
            local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
            local dist = myRoot and math.floor((myRoot.Position - rootPart.Position).Magnitude) or 0
            esp.Distance.Text = string.format("[%d studs]", dist)
            esp.Distance.Position = Vector2.new(textPos.bottom.X, textPos.bottom.Y + 15)
            esp.Distance.Color = DistanceColor
            esp.Distance.Visible = true
        else
            esp.Distance.Visible = false
        end

        if ShowToolName then
            esp.Tool.Text = string.format("[%s]", esp.CurrentToolName)
            esp.Tool.Position = Vector2.new(textPos.bottom.X, textPos.bottom.Y + 30)
            esp.Tool.Color = ToolColor
            esp.Tool.Visible = true
        else
            esp.Tool.Visible = false
        end

        if ShowLine then
            local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
            esp.Line.From = screenCenter
            esp.Line.To = textPos.center
            esp.Line.Color = finalLineColor
            esp.Line.Visible = true
        else
            esp.Line.Visible = false
        end
    end

    local conn = RunService.RenderStepped:Connect(UpdateESP)
    table.insert(esp.Connections, conn)
    
    local character = player.Character
    if character then
        SetupToolTracking(player, character, esp)
    end
    
