-- ==================== CAMERA NOCLIP (Anti-Popper) ====================
local CameraNoclipEnabled = false
local PatchedFunctions = {} -- Menyimpan catatan fungsi dan indeks yang di-patch

if not game:IsLoaded() then
    game.Loaded:wait()
end

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Fungsi Utama untuk Mengatur Noclip Kamera
local function updateNoclipStatus()
    local PlayerScripts = LocalPlayer:FindFirstChild("PlayerScripts")
    local PopperClient = PlayerScripts and PlayerScripts:FindFirstChild("PlayerModule")
        and PlayerScripts.PlayerModule:FindFirstChild("CameraModule")
        and PlayerScripts.PlayerModule.CameraModule:FindFirstChild("ZoomController")
        and PlayerScripts.PlayerModule.CameraModule.ZoomController:FindFirstChild("Popper")
        
    if not PopperClient then return end

    for i, v in next, getgc() do
        if typeof(v) == "function" and getfenv(v).script == PopperClient then
            if CameraNoclipEnabled then
                -- [ON] Cari nilai 0.25, ubah ke 0, dan catat indeksnya
                local constants = debug.getconstants(v)
                local indices = PatchedFunctions[v] or {}
                
                for i2, v2 in next, constants do
                    if tonumber(v2) == 0.25 then
                        debug.setconstant(v, i2, 0)
                        if not table.find(indices, i2) then
                            table.insert(indices, i2)
                        end
                    end
                end
                if #indices > 0 then
                    PatchedFunctions[v] = indices
                end
            else
                -- [OFF] Kembalikan nilai 0 ke 0.25 berdasarkan indeks yang dicatat sebelumnya
                local indices = PatchedFunctions[v]
                if indices then
                    for _, index in ipairs(indices) do
                        debug.setconstant(v, index, 0.25)
                    end
                    PatchedFunctions[v] = nil -- Hapus catatan karena sudah normal
                end
            end
        end
    end
end

