-- ==================== SPIN BOT V2 ====================
local SpinBotV2Enabled = false
local SpinSpeedV2 = 20
local SpinConnectionV2 = nil
local SpinAnglesV2 = {0, 90, 180, 270}
local SpinIndexV2 = 1
local LastSpinTimeV2 = 0

local function StartSpinBotV2()
    if SpinConnectionV2 then SpinConnectionV2:Disconnect() end
    SpinConnectionV2 = game:GetService("RunService").RenderStepped:Connect(function()
        if not SpinBotV2Enabled then return end

        local char = game.Players.LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")

        if hum and hum.Sit then return end
        if not hrp then return end

        local currentTime = tick()
        local delay = 1 / SpinSpeedV2

        if currentTime - LastSpinTimeV2 >= delay then
            LastSpinTimeV2 = currentTime
            SpinIndexV2 = SpinIndexV2 + 1
            if SpinIndexV2 > #SpinAnglesV2 then SpinIndexV2 = 1 end
        end

        local targetAngle = SpinAnglesV2[SpinIndexV2]
        hrp.CFrame = CFrame.new(hrp.Position) * CFrame.Angles(0, math.rad(targetAngle), 0)
    end)
end

SpinBotSection:AddToggle({
    Title = "Enable Spin Bot V2",
    Content = "Rotasi patah-patah, tetap bisa jalan normal",
    Default = false,
    Callback = function(value)
        SpinBotV2Enabled = value
        if value then
            SpinIndexV2 = 1
            LastSpinTimeV2 = 0
            StartSpinBotV2()
            Speed_Library:ShowNotification("Spin Bot V2", "Spin Bot V2 Enabled", 3)
        else
            if SpinConnectionV2 then SpinConnectionV2:Disconnect() end
            Speed_Library:ShowNotification("Spin Bot V2", "Spin Bot V2 Disabled", 3)
        end
    end
})

SpinBotSection:AddSlider({
    Title = "Spin Speed V2",
    Min = 1, Max = 20, Default = 5,
    Callback = function(value) SpinSpeedV2 = value end
})

