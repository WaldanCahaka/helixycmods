-- Fungsi untuk mencari fungsi reload di memori
local function getReloadFunc()
    for _, obj in pairs(getgc(true)) do
        if type(obj) == "function" then
            local info = debug.getinfo(obj)
            if info.name == "reload" and string.find(info.short_src, "GunController") then
                return obj
            end
        end
    end
    return nil
end

local reloadFunc = nil

local function setupAutoReload()
    if ReloadConnection then ReloadConnection:Disconnect() end
    
    ReloadConnection = game:GetService("RunService").Heartbeat:Connect(function()
        if not AutoReloadEnabled then return end
        
        local char = game.Players.LocalPlayer.Character
        local tool = char and char:FindFirstChildOfClass("Tool")
        
        if tool and tool:GetAttribute("ToolType") == "Gun" then
            local ammo = tool:GetAttribute("Local_CurrentAmmo")
            local isReloading = tool:GetAttribute("Local_ReloadSession")
            
            if ammo == 0 and isReloading == 0 then
                -- Cari fungsi reload jika belum ketemu
                if not reloadFunc then reloadFunc = getReloadFunc() end
                
                if reloadFunc then
                    reloadFunc() -- Memanggil fungsi asli game (Animasi + Suara jalan)
                    task.wait(1) -- Debounce agar tidak spam
                end
            end
        end
    end)
end

